# =============================================================================
# SmartLogistica Web — variables de entorno (Next.js)
# Copia este archivo a .env.local. Variables NEXT_PUBLIC_* se exponen al cliente.
# =============================================================================

# URL publica del frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL de la API NestJS (mismo host en dev, distinto en prod)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Nombre de la cookie de sesion (debe coincidir con apps/api)
SESSION_COOKIE_NAME=smartlog_session
