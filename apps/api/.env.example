# =============================================================================
# SmartLogistica API — variables de entorno
# Copia este archivo a .env.local y llena los valores. NO COMMITEAR .env.local.
# Ver DEV_SETUP.md para instrucciones detalladas.
# =============================================================================

# Runtime
NODE_ENV=development
PORT=3001
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

# Control plane DB (compartida — usuarios, tenants, sessions)
CONTROL_PLANE_DATABASE_URL=postgresql://USER:PASS@HOST:PORT/control_plane?sslmode=require

# Tenant provisioning — el role admin debe tener CREATEDB y CREATEROLE
TENANT_DB_HOST=HOST:PORT
TENANT_DB_ADMIN_URL=postgresql://USER:PASS@HOST:PORT/postgres?sslmode=require
TENANT_DB_MASTER_PASSWORD=PASS_DEL_ROLE_ADMIN
TENANT_DB_SSLMODE=require

# Cache + colas
REDIS_URL=redis://default:PASS@HOST:PORT

# =============================================================================
# Crypto (envelope encryption)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =============================================================================
KEK_V1=CHANGE_ME_32_BYTES_BASE64
CURRENT_KEK_VERSION=1

# Sesion
SESSION_SECRET=CHANGE_ME_32_BYTES_BASE64
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
# SameSite de la cookie de sesion: lax (dev / web+API mismo dominio registrable)
# o none (prod cross-site, ej. Vercel + Railway — requiere COOKIE_SECURE=true).
COOKIE_SAMESITE=lax

# Webhook publico — base URL que VTEX/Shopify usan para llegar a nuestra API
# En dev usar `pnpm tunnel` (cloudflared, lo setea solo). En prod: https://api.smartlogistica.app
PUBLIC_WEBHOOK_BASE_URL=https://CHANGE_ME.trycloudflare.com

# Reconciliacion periodica VTEX (mirror de la DB) en ms. 0 = desactivar.
REALTIME_RECONCILE_MS=90000

# Token secreto para el webhook de confirmacion de direccion (Whapify).
# Generar: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CONFIRMATION_WEBHOOK_SECRET=CHANGE_ME
