{
  "name": "@smartlogistica/api",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch --preserveWatchOutput",
    "start": "node dist/main.js",
    "start:workers": "node dist/workers.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "pnpm db:generate:control && pnpm db:generate:tenant",
    "db:generate:control": "prisma generate --schema=prisma/control-plane/schema.prisma",
    "db:generate:tenant": "prisma generate --schema=prisma/tenant/schema.prisma",
    "db:migrate": "dotenv -e .env.local -- prisma migrate deploy --schema=prisma/control-plane/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/control-plane/schema.prisma",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev --schema=prisma/control-plane/schema.prisma",
    "db:migrate:tenant": "dotenv -e .env.local -- prisma migrate dev --schema=prisma/tenant/schema.prisma --create-only",
    "db:tenant:bootstrap-sql": "prisma migrate diff --from-empty --to-schema-datamodel prisma/tenant/schema.prisma --script > prisma/tenant/init.sql",
    "db:studio": "dotenv -e .env.local -- prisma studio --schema=prisma/control-plane/schema.prisma"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.2.1",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "@smartlogistica/shared": "workspace:*",
    "axios": "^1.7.9",
    "bullmq": "^5.34.6",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "lru-cache": "^11.0.2",
    "nestjs-pino": "^4.2.0",
    "pdf-lib": "^1.17.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@smartlogistica/eslint-config": "workspace:*",
    "@smartlogistica/tsconfig": "workspace:*",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
